{
    "manifest_version": 3,
    "name": "Collapse",
    "description": "Collapse multiple YouTube tabs into a single persistent list with saved watch progress.",
    "version": "1.0.0",
    "permissions": [
        "tabs",
        "storage"
    ],
    "host_permissions": [
        "https://www.youtube.com/*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "https://www.youtube.com/*"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_start",
            "world": "MAIN"
        },
        {
            "matches": [
                "https://www.youtube.com/*"
            ],
            "js": [
                "bridge.js"
            ],
            "run_at": "document_start",
            "world": "ISOLATED"
        }
    ],
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "dist/icons/icon16.png",
            "48": "dist/icons/icon48.png",
            "128": "dist/icons/icon128.png"
        }
    },
    "icons": {
        "16": "dist/icons/icon16.png",
        "48": "dist/icons/icon48.png",
        "128": "dist/icons/icon128.png"
    }
}