		"message": "Video $VIDEO_ID$ detected.",
		"placeholders": {
			"video_id": {
				"content": "$1",
				"example": "12345"
			}
		}
	},
	"statusMonitoring": {
		"message": "Monitoring"
	},
	"statusWaitingVideo": {
		"message": "Waiting for a video to play..."
	},
	"btnMarkComplete": {
		"message": "Mark Complete"
	},
	"btnReset": {
		"message": "Reset"
	},
	"btnWaiting": {
		"message": "Waiting..."
	},
	"btnSending": {
		"message": "Sending..."
	},
	"btnStartPlaying": {
		"message": "Start playing a video..."
	},
	"btnBlockingReset": {
		"message": "Blocking $COUNT$ — Reset",
		"placeholders": {
			"count": {
				"content": "$1",
				"example": "2"
			}
		}
	},
	"notOnPage": {
		"message": "Not on AP Classroom"
	},
	"notOnPageSub": {
		"message": "Navigate to apclassroom.collegeboard.org to use this extension."
