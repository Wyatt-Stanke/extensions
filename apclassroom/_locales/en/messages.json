		"message": "Show in-page overlay"
	},
	"howToUseTitle": {
		"message": "How to Use"
	},
	"howToUseStep1": {
		"message": "Navigate to a video on AP Classroom"
	},
	"howToUseStep2": {
		"message": "Start playing the video briefly"
	},
