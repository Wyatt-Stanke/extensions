{
	"extensionName": {
		"message": "AP Classroom Tools"
	},
	"extensionDescription": {
		"message": "Track and manage video watch progress on AP Classroom."
	},
	"statusChecking": {
		"message": "Checking..."
	},
	"statusNotRunning": {
		"message": "Not Running"
	},
	"statusBlockingSingular": {
		"message": "Blocking $COUNT$ video",
		"placeholders": {
			"count": {
				"content": "$1",
				"example": "1"
			}
		}
	},
	"statusBlockingPlural": {
		"message": "Blocking $COUNT$ videos",
		"placeholders": {
			"count": {
				"content": "$1",
				"example": "3"
			}
		}
	},
	"statusBlockingDetail": {
		"message": "Progress requests are being intercepted."
	},
	"statusReady": {
		"message": "Ready"
	},
