{
	"manifest_version": 3,
	"name": "__MSG_extensionName__",
	"description": "__MSG_extensionDescription__",
	"default_locale": "en",
	"version": "1.4.0",
	"permissions": [
		"activeTab",
		"storage"
	],
	"host_permissions": [
		"https://apclassroom.collegeboard.org/*",
		"https://apc-api-production.collegeboard.org/*"
	],
	"background": {
		"service_worker": "dist/background.js"
	},
	"content_scripts": [
		{
			"matches": [
				"https://apclassroom.collegeboard.org/*"
			],
			"js": [
				"dist/content.js"
			],
			"run_at": "document_start",
			"world": "MAIN"
		},
		{
			"matches": [
				"https://apclassroom.collegeboard.org/*"
			],
			"js": [
				"dist/bridge.js"
			],
			"run_at": "document_start",
			"world": "ISOLATED"
		}
	],
	"action": {
		"default_popup": "popup.html",
		"default_icon": {
			"16": "dist/icons/icon16.png",
			"48": "dist/icons/icon48.png",
			"128": "dist/icons/icon128.png"
		}
	},
	"icons": {
		"16": "dist/icons/icon16.png",
		"48": "dist/icons/icon48.png",
		"128": "dist/icons/icon128.png"
	}
}
