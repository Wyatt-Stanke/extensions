{
	"private": true,
	"type": "module",
	"scripts": {
		"build:icons": "node scripts/generate-icons.mjs",
		"build": "npm run build:icons && node scripts/build.mjs",
		"format": "biome format . --fix",
		"lint": "biome lint .",
		"test:type": "tsc --noEmit",
		"test:lint": "biome check . --error-on-warnings",
		"test": "npm run test:type && npm run test:lint",
		"i18n:validate": "node scripts/i18n/validate.mjs",
		"i18n:badge": "node scripts/i18n/badge.mjs",
