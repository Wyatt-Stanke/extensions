		"i18n:translate": "node scripts/i18n/translate.mjs"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.13",
		"chrome-types": "0.1.425",
		"chrome-webstore-upload-cli": "3.5.0",
		"esbuild": "0.28.0",
		"lucide": "1.8.0",
		"sharp": "0.34.5",
		"typescript": "6.0.3"
	}
